# Teradata connection
TERADATA_HOST=
TERADATA_USER=
TERADATA_PASSWORD=

# BigQuery
GOOGLE_CLOUD_PROJECT=

# Default database/dataset (optional — overrides --database argument)
DATABASE=

# Default schema ID (1, 2, or td)
SCHEMA_ID=1

# Default number of rows per table
DEFAULT_ROWS=100

# Generator locale (any valid Faker locale)
GENERATOR_LOCALE=zu_ZA

# Log output directory
# LOG_DIR=./logs
