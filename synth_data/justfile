# synth-data justfile

set dotenv-load

gcp_project := "adg-internal-tech-sandbox"

default:
    @just --list

# ── Quality ──────────────────────────────────────────────────────────────────

lint:
    uv run ruff check .

lint-fix:
    uv run ruff check --fix .

format:
    uv run ruff format .

typecheck:
    uv run pyright

test:
    uv run pytest

# ── BigQuery commands ────────────────────────────────────────────────────────

analyze-bq *ARGS:
    uv run python main.py --engine bigquery --project {{ gcp_project }} analyze {{ ARGS }}

seed-bq dataset table rows:
    uv run python main.py --engine bigquery --project {{ gcp_project }} seed {{ dataset }} {{ table }} --rows {{ rows }}

read-bq dataset table limit:
    uv run python main.py --engine bigquery --project {{ gcp_project }} read {{ dataset }} {{ table }} --limit {{ limit }}

create-schema-bq dataset:
    uv run python main.py --engine bigquery --project {{ gcp_project }} create-schema {{ dataset }}

drop-schema-bq dataset:
    uv run python main.py --engine bigquery --project {{ gcp_project }} drop-schema {{ dataset }}

seed-test-bq dataset:
    uv run python main.py --engine bigquery --project {{ gcp_project }} seed-test {{ dataset }}

# ── Teradata commands ────────────────────────────────────────────────────────

analyze-td *ARGS:
    uv run python main.py --engine teradata analyze {{ ARGS }}

seed-td database table rows:
    uv run python main.py --engine teradata seed {{ database }} {{ table }} --rows {{ rows }}

read-td database table limit:
    uv run python main.py --engine teradata read {{ database }} {{ table }} --limit {{ limit }}

create-schema-td database:
    uv run python main.py --engine teradata create-schema {{ database }}

drop-schema-td database:
    uv run python main.py --engine teradata drop-schema {{ database }}

seed-test-td database:
    uv run python main.py --engine teradata seed-test {{ database }}
