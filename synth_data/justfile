# synth-data justfile
# CLI usage: uv run synth --help

default:
    @just --list

words:
    @wc -l *.py src/*.py tests/*.py 2>/dev/null | grep -v total | sort -rn | awk '{printf "  %6d  %s\n", $1, $2}'
    @echo ""
    @wc -l *.py src/*.py tests/*.py 2>/dev/null | tail -1 | awk '{printf "  %6d  %s\n", $1, $2}'

lint:
    uv run ruff check .

lint-fix:
    uv run ruff check --fix .

format:
    uv run ruff format .

typecheck:
    uv run pyright

test:
    uv run pytest

check: lint typecheck test

all: format check

install:
    uv sync

build:
    uv build

analyse engine database='':
    #!/usr/bin/env bash
    cmd="uv run synth --engine {{engine}} analyse"
    [ -n "{{database}}" ] && cmd="$cmd {{database}}"
    $cmd

seed engine database table='' rows='100' output='':
    #!/usr/bin/env bash
    cmd="uv run synth --engine {{engine}} seed {{database}}"
    [ -n "{{table}}" ] && cmd="$cmd --table {{table}}"
    cmd="$cmd --rows {{rows}}"
    [ -n "{{output}}" ] && cmd="$cmd --output {{output}}"
    $cmd

read engine database table limit='20':
    uv run synth --engine {{engine}} read {{database}} {{table}} --limit {{limit}}

create-schema engine database:
    uv run synth --engine {{engine}} create-schema {{database}}

drop-schema engine database:
    uv run synth --engine {{engine}} drop-schema {{database}}

seed-test engine database output='':
    #!/usr/bin/env bash
    cmd="uv run synth --engine {{engine}} seed-test {{database}}"
    [ -n "{{output}}" ] && cmd="$cmd --output {{output}}"
    $cmd

auth:
    gcloud auth application-default login

set-project:
    @echo "GOOGLE_CLOUD_PROJECT=adg-internal-tech-sandbox" >> .env
    @echo "Project set to adg-internal-tech-sandbox in .env"
