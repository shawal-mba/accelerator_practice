# synth-data justfile

default:
    @just --list

# ── Quality ──────────────────────────────────────────────────────────────────

lint:
    uv run ruff check .

lint-fix:
    uv run ruff check --fix .

format:
    uv run ruff format .

typecheck:
    uv run pyright

test:
    uv run pytest

# ── BigQuery commands ────────────────────────────────────────────────────────

analyze-bq dataset="":
    uv run python main.py --engine bigquery analyze {{ if dataset != "" { "--database " + dataset } else { "" } }}

seed-bq dataset table="" rows=100:
    uv run python main.py --engine bigquery seed {{ dataset }} {{ table }} --rows {{ rows }}

read-bq dataset table limit=20:
    uv run python main.py --engine bigquery read {{ dataset }} {{ table }} --limit {{ limit }}

create-schema-bq dataset:
    uv run python main.py --engine bigquery create-schema {{ dataset }}

drop-schema-bq dataset:
    uv run python main.py --engine bigquery drop-schema {{ dataset }}

seed-test-bq dataset:
    uv run python main.py --engine bigquery seed-test {{ dataset }}

# ── Teradata commands ────────────────────────────────────────────────────────

analyze-td database="":
    uv run python main.py --engine teradata analyze {{ if database != "" { "--database " + database } else { "" } }}

seed-td database table="" rows=100:
    uv run python main.py --engine teradata seed {{ database }} {{ table }} --rows {{ rows }}

read-td database table limit=20:
    uv run python main.py --engine teradata read {{ database }} {{ table }} --limit {{ limit }}

create-schema-td database:
    uv run python main.py --engine teradata create-schema {{ database }}

drop-schema-td database:
    uv run python main.py --engine teradata drop-schema {{ database }}

seed-test-td database:
    uv run python main.py --engine teradata seed-test {{ database }}
