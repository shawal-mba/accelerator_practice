# synth-data justfile

set dotenv-load

gcp_project := "adg-internal-tech-sandbox"

cli := "uv run synth-data"

default:
    @just --list

# ── Stats ────────────────────────────────────────────────────────────────────

words:
    @echo "Lines of code per Python file:"
    @echo ""
    @wc -l *.py lib/*.py tests/*.py 2>/dev/null | grep -v total | sort -rn | awk '{printf "  %6d  %s\n", $1, $2}'
    @echo ""
    @echo "Total:"
    @wc -l *.py lib/*.py tests/*.py 2>/dev/null | tail -1 | awk '{printf "  %6d  %s\n", $1, $2}'

# ── Quality ──────────────────────────────────────────────────────────────────

lint:
    uv run ruff check .

lint-fix:
    uv run ruff check --fix .

format:
    uv run ruff format .

typecheck:
    uv run pyright

test:
    uv run pytest

check: lint typecheck test

all: format check

# ── Build ────────────────────────────────────────────────────────────────────

install:
    uv sync

build:
    uv build

# ── BigQuery commands ────────────────────────────────────────────────────────

analyze-bq *ARGS:
    {{ cli }} --engine bigquery --project {{ gcp_project }} analyze {{ ARGS }}

seed-bq dataset table rows:
    {{ cli }} --engine bigquery --project {{ gcp_project }} seed {{ dataset }} {{ table }} --rows {{ rows }}

read-bq dataset table limit:
    {{ cli }} --engine bigquery --project {{ gcp_project }} read {{ dataset }} {{ table }} --limit {{ limit }}

create-schema-bq dataset:
    {{ cli }} --engine bigquery --project {{ gcp_project }} create-schema {{ dataset }}

drop-schema-bq dataset:
    {{ cli }} --engine bigquery --project {{ gcp_project }} drop-schema {{ dataset }}

purge-data-bq dataset:
    {{ cli }} --engine bigquery --project {{ gcp_project }} purge-data {{ dataset }}

seed-test-bq dataset:
    {{ cli }} --engine bigquery --project {{ gcp_project }} seed-test {{ dataset }}

# ── Teradata commands ────────────────────────────────────────────────────────

analyze-td *ARGS:
    {{ cli }} --engine teradata analyze {{ ARGS }}

seed-td database table rows:
    {{ cli }} --engine teradata seed {{ database }} {{ table }} --rows {{ rows }}

read-td database table limit:
    {{ cli }} --engine teradata read {{ database }} {{ table }} --limit {{ limit }}

create-schema-td database:
    {{ cli }} --engine teradata create-schema {{ database }}

drop-schema-td database:
    {{ cli }} --engine teradata drop-schema {{ database }}

purge-data-td database:
    {{ cli }} --engine teradata purge-data {{ database }}

seed-test-td database:
    {{ cli }} --engine teradata seed-test {{ database }}
