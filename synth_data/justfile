# synth-data justfile
# CLI usage: uv run synth --help

default:
    @just --list

words:
    @wc -l *.py src/*.py tests/*.py 2>/dev/null | grep -v total | sort -rn | awk '{printf "  %6d  %s\n", $1, $2}'
    @echo ""
    @wc -l *.py src/*.py tests/*.py 2>/dev/null | tail -1 | awk '{printf "  %6d  %s\n", $1, $2}'

lint:
    uv run ruff check .

lint-fix:
    uv run ruff check --fix .

format:
    uv run ruff format .

typecheck:
    uv run pyright

test:
    uv run pytest

check: lint typecheck test

all: format check

install:
    uv sync

build:
    uv build

auth:
    gcloud auth application-default login

set-project:
    @echo "GOOGLE_CLOUD_PROJECT=adg-internal-tech-sandbox" >> .env
    @echo "Project set to adg-internal-tech-sandbox in .env"
