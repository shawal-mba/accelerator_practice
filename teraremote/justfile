# Teraremote — Justfile

set dotenv-load

export TERADATA_HOST := "35.195.58.170"
export TERADATA_USER := "dbc"
export TERADATA_PASSWORD := "dbc"

# List all databases
analyze:
    uv run python main.py analyze

# List tables in a database (defaults to DB_DEMO_FOR_SYNTHETIC)
db database='DB_DEMO_FOR_SYNTHETIC':
    uv run python main.py analyze --database {{database}}

# Seed table(s) with fake data and show results
seed database table='' rows='100' output='':
    #!/usr/bin/env bash
    cmd="uv run python main.py seed {{database}}"
    [ -n "{{table}}" ] && cmd="$cmd {{table}}"
    cmd="$cmd --rows {{rows}}"
    [ -n "{{output}}" ] && cmd="$cmd --output {{output}}"
    $cmd
    echo ""
    if [ -n "{{table}}" ]; then
        uv run python main.py read {{database}} {{table}} --limit 20
    else
        tables=$(uv run python main.py analyze --database {{database}} 2>/dev/null | grep -oP '^\s+\K\S+' | grep test_)
        for t in $tables; do
            echo "--- $t ---"
            uv run python main.py read {{database}} $t --limit 5
        done
    fi

# Read rows from a table
read database table limit='20':
    uv run python main.py read {{database}} {{table}} --limit {{limit}}

# Create test tables with all column types
create-schema database:
    uv run python main.py create-schema {{database}}

# Drop all test tables
drop-schema database:
    uv run python main.py drop-schema {{database}}

# Seed test tables with referential integrity
seed-test database output='':
    #!/usr/bin/env bash
    cmd="uv run python main.py seed-test {{database}}"
    [ -n "{{output}}" ] && cmd="$cmd --output {{output}}"
    $cmd

# Run linter
lint:
    uv run ruff check .
    uv run ruff format --check .

# Auto-fix lint and format
fmt:
    uv run ruff check --fix .
    uv run ruff format .

# Show this help
help:
    @just --list
